# ─────────────────────────────────────────────────────────────
# Penyzen — Environment Variables Reference
# Copy to .env.local for local development. NEVER commit .env files.
# In AWS Lambda, set these via CDK as Lambda environment variables.
# Sensitive values (marked *SECRET*) must live in Secrets Manager.
# ─────────────────────────────────────────────────────────────

# Application
NODE_ENV=development
APP_NAME=Penyzen
APP_URL=https://www.penyzen.com
API_URL=https://api.penyzen.com
LOG_LEVEL=info
PLATFORM_FEE_PERCENT=2.5

# Database (*SECRET* — store in Secrets Manager in production)
DATABASE_URL=postgresql://penyzen:password@localhost:5432/penyzen_dev?schema=public
DB_SECRET_ARN=arn:aws:secretsmanager:us-east-1:123456789:secret:penyzen/db/credentials

# AWS
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=123456789012

# Cognito
COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
COGNITO_APP_CLIENT_ID=XXXXXXXXXXXXXXXXXXXXXXXXXX
COGNITO_REGION=us-east-1

# Stripe (*SECRET* — store in Secrets Manager in production)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_IDENTITY_WEBHOOK_SECRET=whsec_...
STRIPE_CONNECT_REDIRECT_URL=https://api.penyzen.com/v1/connect/callback

# S3 / CloudFront
S3_MEDIA_BUCKET=penyzen-media-dev
S3_RECEIPTS_BUCKET=penyzen-receipts-dev
CLOUDFRONT_DOMAIN=https://d1234567890.cloudfront.net

# SQS
SQS_NOTIFICATION_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/penyzen-notifications-dev

# SES
SES_FROM_EMAIL=noreply@penyzen.com
SES_REPLY_TO=support@penyzen.com
SES_REGION=us-east-1
