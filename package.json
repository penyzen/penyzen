{
  "name": "penyzen",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "services/*",
    "infra"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "eslint packages services --ext .ts",
    "test": "vitest run",
    "db:generate": "npm run db:generate --workspace=packages/database",
    "db:migrate:dev": "npm run db:migrate:dev --workspace=packages/database",
    "db:migrate:deploy": "npm run db:migrate:deploy --workspace=packages/database",
    "db:studio": "npm run db:studio --workspace=packages/database",
    "infra:deploy": "npm run deploy --workspace=infra",
    "infra:diff": "npm run diff --workspace=infra",
    "infra:synth": "npm run synth --workspace=infra"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "prettier": "^3.3.3",
    "typescript": "^5.5.4",
    "esbuild": "^0.23.0",
    "vitest": "^2.0.5"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
